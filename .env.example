# ── FastScores (ClassPro) ──────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Crypto Bot (Supabase riêng) ───────────────────────
BOT_SUPABASE_URL=https://yyyy.supabase.co
BOT_SUPABASE_SERVICE_KEY=your_bot_service_role_key_here

# ── Crypto Bot ────────────────────────────────────────
# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Symbols to track (comma-separated)
RSI_SYMBOLS=ETHUSDT,BTCUSDT

# OpenRouter AI analysis (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

# Bot check interval (minutes)
RSI_CHECK_MINUTES=5

# Notification cooldown between repeat signals (minutes)
NOTIFY_COOLDOWN_MINUTES=120
