# ── ClassPro / FastScores (report viewer) ─────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# ── Crypto Bot (separate Supabase project, can be the same) ───────────────────
BOT_SUPABASE_URL=https://<project-ref>.supabase.co
BOT_SUPABASE_SERVICE_KEY=<service-role-key>

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>
# Fallback chat IDs if getUpdates returns nothing (comma-separated)
TELEGRAM_CHAT_IDS=

# ── Crypto bot settings ───────────────────────────────────────────────────────
# Symbols to track (comma-separated Binance pairs)
RSI_SYMBOLS=ETHUSDT,BTCUSDT
# Strategy mode: default | optimized
BOT_MODE=default
# Minimum minutes between repeated notifications for the same symbol
NOTIFY_COOLDOWN_MINUTES=120

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-<your-key>
# Model 1 – trend/correlation analysis
OPENROUTER_MODEL=google/gemini-2.5-pro
# Model 2 – risk analysis (leave blank to disable)
OPENROUTER_MODEL2=deepseek/deepseek-r1
